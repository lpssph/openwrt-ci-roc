CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y

CONFIG_ATH11K_MEM_PROFILE_512M=y
CONFIG_NSS_FIRMWARE_VERSION_12_5=y

CONFIG_PACKAGE_luci-app-openlist2=n
CONFIG_PACKAGE_luci-app-athena-led=n
CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=n
CONFIG_PACKAGE_luci-app-lucky=n
CONFIG_PACKAGE_luci-app-gecoosac=n
CONFIG_PACKAGE_luci-app-dockerman=n

CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_hostapd-common=n

CONFIG_PACKAGE_kmod-ppp=n
CONFIG_PACKAGE_kmod-pppoe=n
CONFIG_PACKAGE_kmod-pppol2tp=n
CONFIG_PACKAGE_kmod-pptp=n
CONFIG_PACKAGE_kmod-pppox=n
CONFIG_PACKAGE_kmod-l2tp=n
CONFIG_PACKAGE_kmod-mppe=n
CONFIG_PACKAGE_luci-proto-ppp=n
CONFIG_PACKAGE_ppp=n
CONFIG_PACKAGE_ppp-mod-pppoe=n
# 核心 USB 驱动
CONFIG_PACKAGE_kmod-usb-core=n
CONFIG_PACKAGE_kmod-usb3=n
CONFIG_PACKAGE_kmod-usb-xhci-hcd=n
CONFIG_PACKAGE_kmod-usb-dwc3=n
CONFIG_PACKAGE_kmod-usb-dwc3-qcom=n
CONFIG_PACKAGE_kmod-usb-storage=n
CONFIG_PACKAGE_kmod-usb-storage-extras=n
CONFIG_PACKAGE_kmod-usb-storage-uas=n

# 文件系统与磁盘工具
CONFIG_PACKAGE_kmod-fs-exfat=n
CONFIG_PACKAGE_kmod-fs-ext4=n
CONFIG_PACKAGE_kmod-fs-f2fs=n
CONFIG_PACKAGE_kmod-fs-ntfs3=n
CONFIG_PACKAGE_kmod-fs-vfat=n
CONFIG_PACKAGE_e2fsprogs=n
CONFIG_PACKAGE_f2fs-tools=n
CONFIG_PACKAGE_f2fsck=n
CONFIG_PACKAGE_mkf2fs=n
CONFIG_PACKAGE_block-mount=n
CONFIG_PACKAGE_automount=n
CONFIG_PACKAGE_ntfs3-mount=n
# 删掉这个（网页里的设置插件）
CONFIG_PACKAGE_luci-app-uhttpd=n
CONFIG_PACKAGE_luci-i18n-uhttpd-zh-cn=n

# 必须保留下面这些（这是网页后台运行的基础）
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_liblucihttp=y


# 删除过时的 IPv6 隧道协议
# CONFIG_PACKAGE_6rd is not set
# CONFIG_PACKAGE_6to4 is not set
# CONFIG_PACKAGE_6in4 is not set
# CONFIG_PACKAGE_kmod-sit is not set
# CONFIG_PACKAGE_kmod-nat46 is not set
# CONFIG_PACKAGE_kmod-ip6-tunnel is not set
# CONFIG_PACKAGE_kmod-iptunnel6 is not set
# CONFIG_PACKAGE_kmod-udptunnel6 is not set
# 删除 NSS 无线和没用的隧道加速
# CONFIG_PACKAGE_kmod-qca-nss-drv-wifi-meshmgr is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-tun6rd is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-tunipip6 is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-map-t is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-gre is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-pptp is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-l2tpv2 is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-vxlanmgr is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-mirror is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-match is not set
