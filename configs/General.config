# 3. 补全透明代理和加密所需的依赖 (256MB 设备必带)
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nf-tproxy=y
CONFIG_SINGBOX_WITH_QUIC=y
CONFIG_SINGBOX_WITH_HYSTERIA=y
CONFIG_SINGBOX_WITH_HYSTERIA2=y
CONFIG_SINGBOX_WITH_TLS=y
CONFIG_SINGBOX_WITH_UTLS=y
CONFIG_SINGBOX_WITH_CLASH_API=y

#  3. IPv6 保留与精简 (保留双栈，剔除隧道) ###
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_6rd=n
CONFIG_PACKAGE_6to4=n
CONFIG_PACKAGE_kmod-sit=n
CONFIG_PACKAGE_kmod-nat46=n
CONFIG_PACKAGE_kmod-ip6-tunnel=n
CONFIG_PACKAGE_kmod-iptunnel6=n
# 4. 彻底剔除无线及无用 NSS 驱动 (无无线环境)

CONFIG_PACKAGE_kmod-qca-nss-drv-wifi-meshmgr=n
CONFIG_PACKAGE_kmod-qca-nss-drv-pptp=n
CONFIG_PACKAGE_kmod-qca-nss-drv-l2tpv2=n
CONFIG_PACKAGE_kmod-qca-nss-drv-gre=n
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=n
CONFIG_PACKAGE_kmod-qca-nss-drv-tun6rd=n
CONFIG_PACKAGE_kmod-qca-nss-drv-vxlanmgr=n
# 5. 冗余工具与界面精简
CONFIG_PACKAGE_coreutils=n
CONFIG_PACKAGE_coreutils-base64=n
CONFIG_PACKAGE_coreutils-nohup=n
CONFIG_PACKAGE_ethtool=n

# 2. 256MB 内存专项优化 (ZRAM & 系统缓存) ###
CONFIG_PACKAGE_zram-swap=y
CONFIG_ZRAM_SETTINGS_ZRAM_SIZE=128
CONFIG_PACKAGE_kmod-lib-zstd=y
CONFIG_LOGD_BUFFER_SIZE=16
